{
    "manifest_version": 3,
    "name": "Canny extension for End-users",
    "description": "Improve usability of canny.io for end-users",
    "version": "1.1.0",
    "icons": {
        "48": "/images/icon1_48.png",
        "128": "/images/icon1_128.png"
    },
    "action": {
        "default_icon": {
            "48": "/images/icon1_48.png",
            "128": "/images/icon1_128.png"
        },
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js",
        "scripts": ["background.js"]
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.canny.io/*",
                "https://feedback.vrchat.com/*"
            ],
            "js": [
                "content_script_canny.js"
            ],
            "css": [
                "content_script_canny.css"
            ]
        }
    ],
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://*.canny.io/*",
        "https://feedback.vrchat.com/*"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "{bb1da3d2-da52-479c-886b-06d4ed9fa5a3}",
            "strict_min_version": "140.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    }
}
